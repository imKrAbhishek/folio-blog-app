# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
PORT=5000
NODE_ENV=development
# NODE_ENV controls cookie security (see utils/cookieOptions.js):
#   development -> secure: false  (cookie works over plain http://localhost)
#   production  -> secure: true   (cookie only sent over HTTPS)

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/blog-app

# ------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------
# Use a long, random, unguessable string in real environments.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------
# Media Uploads (Cloudinary)
# ------------------------------------------------------------------
# Find these on your Cloudinary Dashboard: https://console.cloudinary.com
# Used by config/cloudinary.js -> middleware/uploadMiddleware.js
CLOUDINARY_CLOUD_NAME=replace_with_your_cloud_name
CLOUDINARY_API_KEY=replace_with_your_api_key
CLOUDINARY_API_SECRET=replace_with_your_api_secret
